# =============================================================================
# Family Ledger - User Configuration
# =============================================================================
# Copy this file to .env and customize the values below.
# Then run: docker compose up -d
# =============================================================================

# REQUIRED: Change to a secure password!
POSTGRES_PASSWORD=change-me-to-a-secure-password

# REQUIRED: Update the password in the DATABASE_URL to match POSTGRES_PASSWORD
# Format: postgresql+psycopg://user:password@host:port/database
FAMILY_LEDGER_DATABASE_URL=postgresql+psycopg://family_ledger:change-me-to-a-secure-password@postgres:5432/family_ledger

# Optional: Uncomment and customize if needed
# POSTGRES_DB=family_ledger
# POSTGRES_USER=family_ledger
