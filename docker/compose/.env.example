# Copy this file to `.env` before starting the stack.
#
# Example:
# docker compose -f docker/compose/docker-compose.yml --env-file docker/compose/.env up -d

# Required.
FAMILY_LEDGER_API_TOKEN=change-me-to-a-long-random-token

# Optional attachment storage via Paperless-ngx.
# FAMILY_LEDGER_PAPERLESS_BASE_URL=http://paperless:8000
# FAMILY_LEDGER_PAPERLESS_TOKEN=change-me-to-a-paperless-api-token
# FAMILY_LEDGER_PAPERLESS_TAG_IDS=12
# If Paperless runs on a docker-internal hostname, set this to the externally accessible URL
# so stored document_url values are usable from outside the container network.
# FAMILY_LEDGER_PAPERLESS_EXTERNAL_BASE_URL=https://paperless.example.com

# Optional overrides.
# FAMILY_LEDGER_IMAGE=ghcr.io/fterrier/family-ledger:latest
# FAMILY_LEDGER_LEDGER_CONFIG_PATH=/app/config/ledger.yaml
# FAMILY_LEDGER_PAPERLESS_API_VERSION=10  # set to 9 for older Paperless instances
# FAMILY_LEDGER_PAPERLESS_POLL_INTERVAL_SECONDS=30
# FAMILY_LEDGER_PAPERLESS_INGESTION_TIMEOUT_SECONDS=900
# FAMILY_LEDGER_ATTACHMENT_POLLER_ENABLED=true
