# Copy this file to `.env` before starting the stack.
#
# Example:
# docker compose -f docker/compose/docker-compose.yml --env-file docker/compose/.env up -d

# Required: change this password before deploying.
POSTGRES_PASSWORD=change-me-to-a-secure-password

# Optional overrides.
# POSTGRES_DB=family_ledger
# POSTGRES_USER=family_ledger
# FAMILY_LEDGER_IMAGE=ghcr.io/fterrier/family-ledger:latest
# FAMILY_LEDGER_LEDGER_CONFIG_PATH=/app/config/ledger.yaml
