# =============================================================================
# Family Ledger settings
# =============================================================================

# Database connection
# The database URL uses credentials from POSTGRES_USER and POSTGRES_PASSWORD.
# Format: postgresql+psycopg://user:password@host:port/database
# FAMILY_LEDGER_DATABASE_URL=postgresql+psycopg://family_ledger:family_ledger@postgres:5432/family_ledger

# Path to the ledger configuration file inside the container.
# Default: /app/config/ledger.yaml
# FAMILY_LEDGER_LEDGER_CONFIG_PATH=/app/config/ledger.yaml

# Application environment (development, production)
# FAMILY_LEDGER_APP_ENV=development
